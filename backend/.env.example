# DATABASE CONFIGURATION
DB_LOCATION=your_mongodb_connection_string_here

# SECURITY CONFIGURATION (JWT SECTOR)
SECRET_ACCESS_KEY=your_jwt_access_secret_here
REFRESH_TOKEN_SECRET=your_jwt_refresh_secret_here
JWT_SECRET=your_jwt_secret_here

# AWS S3 STORAGE CONFIGURATION
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_BUCKET_NAME=your_aws_s3_bucket_name_here
AWS_BUCKET_REGION=your_aws_s3_region_here
AWS_SDK_JS_SUPPRESS_MAINTENANCE_MODE_MESSAGE=1

# EMAIL (SMTP CONFIGURATION)
EMAIL_USER=your_email_user_here
EMAIL_PASS=your_email_app_password_here

# GOOGLE AUTH (OAUTH2)
OAUTH_CLIENT_ID=your_google_oauth_client_id_here
OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token_here

# MAILTRAP CONFIGURATION (Optional for testing)
MAILTRAP_USERNAME=your_mailtrap_username_here
MAILTRAP_PASSWORD=your_mailtrap_password_here

# BREVO (SENDINBLUE) SMTP CONFIGURATION
SENDINBLUE_USER=your_brevo_username_here
SENDINBLUE_API_KEY=your_brevo_api_key_here

# GOOGLE CUSTOM SEARCH API CONFIGURATION
GOOGLE_SEARCH_URL=https://www.googleapis.com/customsearch/v1
GOOGLE_API_KEY=your_google_custom_search_api_key_here
GOOGLE_CX=your_google_custom_search_cx_id_here

# CLIENT URLS FOR CORS OR CALLBACKS
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:3001

# SUPABASE STORAGE CONFIGURATION
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_BUCKET=your_supabase_bucket_name_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# GEMINI AI API KEY
GEMINI_API_KEY=your_gemini_ai_api_key_here
